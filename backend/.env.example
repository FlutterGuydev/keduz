APP_NAME="KED UZ Admin API"
ENVIRONMENT=development

# For immediate local testing, use SQLite:
# DATABASE_URL=sqlite:///./keduz_admin.db

# PostgreSQL-ready config:
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/keduz_admin

SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# JSON list of allowed frontend origins.
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
BACKEND_PUBLIC_URL=http://127.0.0.1:8000

# BILLZ API integration.
BILLZ_API_URL=https://your-billz-api-url
BILLZ_SECRET_KEY=your_billz_secret_key
BILLZ_ISS=ecommerce-site.uz
BILLZ_SUB=your_billz_username
BILLZ_AUTH_ENDPOINT=/v1/auth/login
BILLZ_PRODUCTS_ENDPOINT=/v2/products
BILLZ_PRODUCTS_METHOD=GET

# Telegram order notifications.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
